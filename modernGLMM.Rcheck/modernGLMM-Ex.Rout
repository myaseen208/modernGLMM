> ### Name: Exam18.1
> ### Title: Example 18.1 — Gaussian Spatial Variability: Alliance Wheat
> ###   Trial
> ### Aliases: Exam18.1
> 
> ### ** Examples
> 
> data(DataSet18.1)
> 
> ## -------------------------------------------------------
> ## 1. Baseline: complete block model (no spatial covariance)
> ## -------------------------------------------------------
> fit_rcb <- stats::lm(y ~ trt + block, data = DataSet18.1)
