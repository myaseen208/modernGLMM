> ## -------------------------------------------------------
> ## 2. RCB model (complete block — baseline)
> ## -------------------------------------------------------
> fit_rcb <- lme4::glmer(
+   cbind(y, n - y) ~ variety + (1 | block),
+   family  = stats::binomial(link = "logit"),
+   data    = DataSet18.2,
+   control = lme4::glmerControl(optimizer = "bobyqa")
+ )
