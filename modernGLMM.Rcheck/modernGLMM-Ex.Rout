+   emmeans::contrast(
+     emmeans::emmeans(object = Exam3.3.lm1, specs = ~ trt),
+     list(trt = c(-1, 0, 1, 0))
+   )
+ 
+   ## Average (Trt0+1) vs Average (Trt2+3)
+   emmeans::contrast(
+     emmeans::emmeans(object = Exam3.3.lm1, specs = ~ trt),
+     list(trt = c(-1/2, 1/2, 1/2, -1/2))
+   )
+ 
+   ## Trt1 vs Average (Trt0+1+2)
+   emmeans::contrast(
+     emmeans::emmeans(object = Exam3.3.lm1, specs = ~ trt),
+     list(trt = c(1/3, 1/3, -1, 1/3))
+   )
