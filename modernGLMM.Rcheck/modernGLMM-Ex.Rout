+   data   = DataSet18.1,
+   method = "REML"
+ )
> 
> ## Gaussian covariance
> fit_gau <- nlme::gls(
+   model       = y ~ trt + block,
+   correlation = nlme::corGaus(
+     form   = ~ row + col,
+     nugget = FALSE
+   ),
+   data   = DataSet18.1,
+   method = "REML"
+ )
